@startuml
skin rose
skinparam ActivityFontSize 15
skinparam ArrowFontSize 12

start
:Parse pin/unpin command;
:Find all matching contacts using targetInfo;
:Filter matches by pin status\n(unpinned contacts for pin command;\npinned contacts for unpin command);

if () then ([no filtered matches found])
  if () then ([no contact matches])
    :Show no match error;
  else ([all matches already pinned/unpinned])
    :Show already pinned/unpinned error;
  endif
else ([filtered matches found])
  if () then ([multiple filtered matches])
    :Update UI to show ambiguous matches\nin list;
    :Show disambiguation error;
  else ([single filtered match])
    if () then ([pin command])
      :Pin the contact;
    else ([unpin command])
      :Unpin the contact;
    endif
    :Reorder list with pinned contacts first;
  endif
endif

stop
@enduml
