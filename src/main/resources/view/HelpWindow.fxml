<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.stage.Stage?>

<?import javafx.scene.layout.GridPane?>

<fx:root resizable="false" title="Help" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <icons>
    <Image url="@/images/help_icon.png" />
  </icons>
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@HelpWindow.css" />
      </stylesheets>
      <GridPane fx:id="helpMessageContainer" hgap="15" vgap="15" style="-fx-padding: 20; -fx-background-color: #333333;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
        <Label fx:id="helpMessage" text="Label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Button fx:id="copyButton" mnemonicParsing="false" onAction="#copyUrl" text="Copy URL" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label fx:id="localHelpMessage" text="Label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Button fx:id="openLocalHelp" mnemonicParsing="false" onAction="#openOfflineHelp" text="Launch Offline Help" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
      </GridPane>
    </Scene>
  </scene>
</fx:root>
