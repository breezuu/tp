@startuml
skin rose
skinparam ActivityFontSize 15
skinparam ArrowFontSize 12

start
:Parse pin/unpin command;
:Find matching persons using targetInfo;

if () then ([no matches])
  :Show no match error only;
else ([matches found])
  if () then ([multiple matches])
    :Update UI to show ambiguous matches\nin list;
    :Show error;
  else ([single match])
    if () then ([pin command])
      if () then ([already pinned])
        :Show already pinned error;
      else ([not pinned])
        :Pin the contact;
        :Reorder list with pinned contacts first;
      endif
    else ([unpin command])
      if () then ([already unpinned])
        :Show already unpinned error;
      else ([pinned])
        :Unpin the contact;
        :Reorder list with pinned contacts first;
      endif
    endif
  endif
endif

stop
@enduml
